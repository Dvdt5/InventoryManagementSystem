
@{
    ViewData["Title"] = "Delete Transaction";
}

@model InventoryTransactionModel

<div class="card border-danger">
    <div class="card-header bg-danger text-white">
        Deleting Transaction
    </div>
    <div class="card-body">
        <h5 class="card-title">Are you sure you want to delete this transaction?</h5>
        <dl class="row">
            <dt class="col-sm-3">Reference Number</dt>
            <dd class="col-sm-9">@Model.ReferenceNumber</dd>

            <dt class="col-sm-3">Quantity</dt>
            <dd class="col-sm-9">@Model.Quantity.ToString("C")</dd>

            <dt class="col-sm-3">Remarks</dt>
            <dd class="col-sm-9">@Model.Remarks</dd>

            <dt class="col-sm-3">Product ID</dt>
            <dd class="col-sm-9">@Model.ProductId</dd>

            <dt class="col-sm-3">Warehouse ID</dt>
            <dd class="col-sm-9">@Model.WarehouseId</dd>
        </dl>

        <form asp-controller="Product" asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>


