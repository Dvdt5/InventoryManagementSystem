
@{
    ViewData["Title"] = "Inventory Stocks";
}

<h1>Inventory Stocks</h1>


<div class="table-responsive px-3">
    <a class="btn btn-primary mb-3" asp-action="Add">Add Inventory Stock</a>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Product Name</th>
                <th>Warehouse Name</th>
                <th>QuantityOnHand</th>
                <th>QuantityReserved</th>
                <th>LastUpdated</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (InventoryStockModel item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.WarehouseName</td>
                    <td>@item.QuantityOnHand</td>
                    <td>@item.QuantityReserved</td>
                    <td>@item.LastUpdated</td>
                    <td>
                        <a class="btn btn-warning" asp-action="Update" asp-route-id="@item.Id">Update</a>
                        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>