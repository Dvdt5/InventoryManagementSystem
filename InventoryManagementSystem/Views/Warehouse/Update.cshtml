
@{
    ViewData["Title"] = "Update";
}


@model WarehouseModel

<div class="container mt-5">
    <h2>Update Warehouse</h2>
    <form asp-controller="Warehouse" asp-action="Add" method="post">

        <div class="mb-3 col-12 row">
            <!-- Name -->
            <div class="mb-3 col-6">
                <label asp-for="Name" class="form-label">Name</label>
                <input type="text" id="warehouseName" class="form-control" asp-for="Name" required>
            </div>

            <div class="mb-3 col-6">
                <label asp-for="ManagerName" class="form-label">Manager Name</label>
                <input type="text" id="warehouseManager" class="form-control" asp-for="ManagerName" required>
            </div>
        </div>


        <div class="mb-3 col-12 row d-flex justify-content-center">
            <label asp-for="Location" class="form-label text-left">Location</label>
            <textarea class="form-control" asp-for="Location" id="warehouseLocation" rows="3"></textarea>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-primary">Submit</button>
        <a class="btn btn-danger" asp-action="Index">Cancel</a>
    </form>
</div>


