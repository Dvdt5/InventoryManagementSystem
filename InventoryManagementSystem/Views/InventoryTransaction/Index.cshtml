
@{
    ViewData["Title"] = "Inventory Transactions";
}

<h1>Inventory Transactions</h1>


<div class="table-responsive px-3">
    <a class="btn btn-primary mb-3" asp-action="Add">Add Transactions</a>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Transaction ID</th>
                <th>Product ID</th>
                <th>Warehouse ID</th>
                <th>Transaction Type</th>
                <th>Quantity</th>
                <th>Transaction Date</th>
                <th>Reference Number</th>
                <th>Remarks</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (InventoryTransactionModel item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.ProductId</td>
                    <td>@item.WarehouseId</td>
                    <td>@item.TransactionType</td>
                    <td>@item.Quantity</td>
                    <td>@item.TransactionDate</td>
                    <td>@item.ReferenceNumber</td>
                    <td>@item.Remarks</td>
                    <td>
                        <a class="btn btn-warning" asp-action="Update" asp-route-id="@item.Id">Update</a>
                        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

